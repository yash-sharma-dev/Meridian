{
  "compilerOptions": {
    "checkJs": true,
    "strict": false,
    "noImplicitAny": false,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowJs": true,
    "maxNodeModuleJsDepth": 0,
    "skipLibCheck": true
  },
  "include": [
    "seed-forecasts.mjs",
    "seed-forecasts.types.d.ts",
    "seed-regional-snapshots.mjs",
    "regional-snapshot/**/*.mjs",
    "../shared/regions.types.d.ts",
    "../shared/geography.d.ts"
  ],
  "exclude": []
}
